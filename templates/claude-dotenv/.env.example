# .claude/.env — параметры SSH-доступа для AI-агента (gitignored, не коммитить!)
#
# Один сервер = группа ключей с префиксом роли: SSH_<ROLE>_*.
# Реестр всех настроенных префиксов перечислен в SSH_SERVERS (csv).
# Этот файл управляется командой `seomi-ssh init` / `seomi-ssh update`.

# Реестр настроенных серверов (csv префиксов, в порядке добавления)
SSH_SERVERS=PROD,DEV

# --- prod ---
SSH_PROD_HOST=prod.example.com
SSH_PROD_USER=ai-agent
SSH_PROD_PORT=22
SSH_PROD_KEY=~/.ssh/id_ed25519
SSH_PROD_ROOT=/var/www/app

# --- dev ---
SSH_DEV_HOST=dev.example.com
SSH_DEV_USER=deploy
SSH_DEV_PORT=22
SSH_DEV_KEY=~/.ssh/id_ed25519
SSH_DEV_ROOT=/home/deploy/app
